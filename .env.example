# Copy to .env and fill in values

# Your Linear API key (from https://linear.app/settings/api)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Absolute paths to the repos Claude should work in.
# Set DOCS_REPO_PATH and/or MONOREPO_PATH to enable multi-repo support.
# The agent will receive both paths and choose the relevant repo(s) per issue.
# Falls back to REPO_PATH (or cwd) when neither is set.
DOCS_REPO_PATH=/path/to/your/docs-repo
MONOREPO_PATH=/path/to/your/monorepo

# Legacy single-repo fallback (used only when DOCS_REPO_PATH and MONOREPO_PATH are both unset)
# REPO_PATH=/path/to/your/repo

# GitHub CLI token (create at https://github.com/settings/tokens with repo + workflow scopes)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API key for Claude (https://console.anthropic.com/settings/keys)
# For enterprise accounts, use the API key issued by your organization
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: override the Anthropic API base URL for enterprise/self-hosted deployments
# Leave unset to use the default (https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://your-enterprise-claude-endpoint

# Optional: log file path (defaults to linear-pr-gen.log in the project root)
# LOG_FILE=/var/log/linear-pr-gen.log

# Optional: Pushover notifications on agent completion/failure
# Get your app token at https://pushover.net/apps and user key from your account dashboard
# PUSHOVER_TOKEN=axxxxxxxxxxxxxxxxxxxxxxxxxxx
# PUSHOVER_USER=uxxxxxxxxxxxxxxxxxxxxxxxxxxx
